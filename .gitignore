# ─────────────────────────────────────────────────────────────────────────────
# Kestrel — .gitignore
# Native C (MSVC / Visual Studio). No managed runtime, no package managers.
# ─────────────────────────────────────────────────────────────────────────────

# ── Build output directories ────────────────────────────────────────────────
[Dd]ebug/
[Rr]elease/
[Dd]ebug[Pp]ublic/
[Rr]eleases/
x64/
x86/
[Ww]in32/
[Bb]in/
[Oo]bj/
[Bb]uild/
[Oo]ut/

# ── Compiler / linker intermediates & artifacts ─────────────────────────────
*.obj
*.o
*.exe
*.dll
*.lib
*.exp
*.pdb
*.ilk
*.idb
*.pch
*.ipch
*.res
*.tlog
*.lastbuildstate
*.unsuccessfulbuild
*.log

# ── Visual Studio IDE / cache / per-user files ──────────────────────────────
.vs/
*.user
*.suo
*.sdf
*.opensdf
*.VC.db
*.VC.VC.opendb
*.VC.opendb
*.aps
*.ncb
ipch/
*.cachefile

# ── CMake (only if you ever add it) ─────────────────────────────────────────
CMakeCache.txt
CMakeFiles/
cmake-build-*/

# ── Editors ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*~

# ── OS junk ─────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# ── Scan output — NEVER commit ──────────────────────────────────────────────
# Kestrel's --report writes a live graph of a real domain (SIDs, DNs, trust
# topology, roastable accounts). That is exactly what must not land in a public
# repo. Keep generated reports in a dedicated, ignored folder.
reports/
out/
*.report.html
*.report.json
*.report.yaml
